<!DOCTYPE html>
<html lang="en">
<%- include('./partials/head.ejs') %>
<body>
    <%- include('./partials/nav.ejs') %>

    <main class="home content">
    <section class="home-hero">

        <h1>Stories moving through Blogify right now</h1>
        <p>Explore trending ideas, experiences, and knowledge shared by our community of writers.</p>

    </section>


    <!-- Trending Blogs -->
    
        <% if (blogs && blogs.length > 0) { %>
            <% const topBlog = blogs[0]; %>
            <section class="top-stories">
                <article class="lead-story">
                    <a href="/blogs/<%= topBlog._id %>">
                        <% if(topBlog.image){ %>
                            <img src="/uploads/<%= topBlog.image %>" alt="blog image">
                        <% } %>
                        <div class="story-copy">
                            <p class="eyebrow"><%= topBlog.genre || 'Featured' %></p>
                            <h2 class="blog-title"><%= topBlog.title %></h2>
                            <p><%= topBlog.snippet %></p>
                        </div>
                    </a>
                </article>

                <aside class="side-stories" aria-label="More top stories">
                    <% blogs.slice(1, 3).forEach((blog, index) => { %>
                        <article class="side-story" data-search="<%= `${blog.title} ${blog.snippet} ${blog.genre || ''}` %>" data-category="<%= blog.genre || 'All' %>">
                            <a href="/blogs/<%= blog._id %>">
                                <span class="rank"><%= index + 2 %></span>
                                <div>
                                    <p class="eyebrow"><%= blog.genre || 'Story' %></p>
                                    <h3><%= blog.title %></h3>
                                    <p><%= blog.snippet %></p>
                                </div>
                            </a>
                        </article>
                    <% }) %>
                </aside>
            </section>
        <% } %>
        
        
        <!-- Latest Blogs -->
        <section class="blogs-section">
            <div class="section-heading">
                <h2>Fresh Stories</h2>
            </div>
            
            <div class="latest latest-list">
                <% blogs.slice(0,3).forEach((blog, index) => { %>
                    <article data-search="<%= `${blog.title} ${blog.snippet} ${blog.body} ${blog.genre || ''}` %>" data-category="<%= blog.genre || 'All' %>">
                        <a href="/blogs/<%= blog._id %>">
                            <span class="rank"><%= index + 1 %></span>
                            <div>
                                <p class="eyebrow"><%= blog.genre || 'Latest' %></p>
                                <h3><%= blog.title %></h3>
                                <p><%= blog.body.replace(/<[^>]*>/g, '').substring(0,150) %>...</p>
                            </div>
                        </a>
                    </article>
                    <% }) %>
                </div>
            </section>
            
        </main>
            

 <%- include('./partials/footer.ejs') %>
</body>
</html>